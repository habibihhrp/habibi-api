# PostgreSQL connection string (gunakan Neon / Supabase / Vercel Postgres free tier)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret untuk JWT (generate random string panjang, contoh: openssl rand -base64 32)
JWT_SECRET="ganti_dengan_string_random_panjang_minimal_32_karakter"

# OpenAI API key (untuk endpoint /api/v1/ai). Optional kalau gak pakai AI chat.
OPENAI_API_KEY="sk-xxxxxx"
